# Neo4j Graph Database Configuration

# Mode: 'docker' (for local development) or 'cloud' (for AuraDB production)
NEO4J_MODE=docker

# --- Docker Local Settings ---
NEO4J_DOCKER_URI=bolt://localhost:7687
NEO4J_DOCKER_USER=neo4j
NEO4J_DOCKER_PASSWORD=khadok2025

# --- AuraDB Cloud Settings ---
NEO4J_CLOUD_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_CLOUD_USER=neo4j
NEO4J_CLOUD_PASSWORD=your_secure_password
